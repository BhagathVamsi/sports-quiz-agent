# Copy this file to ".env" and fill in your real values.
# NEVER commit the actual .env file to GitHub.

# Which LLM backend to use: "openai", "anthropic", or "gemini"
# Gemini has a genuine free tier (no credit card needed) -- easiest to start with.
LLM_PROVIDER=gemini

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Required if LLM_PROVIDER=gemini
# Get a free key (no credit card) at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-flash-latest
